# Copy to .env and fill in real values. .env is gitignored.
# Canonical values live in your password manager, not on disk.

# ----- Google OAuth (Gmail, Drive, Sheets, Docs, Calendar) -----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=https://n8n.projectnexuscode.org/oauth2/callback

# ----- Gemini -----
GEMINI_API_KEY=
GEMINI_PROJECT_NUMBER=
GEMINI_PROJECT_ID=

# ----- OpenAI -----
OPENAI_API_KEY=

# ----- Anthropic -----
ANTHROPIC_API_KEY=

# ----- Cloudflare Tunnel -----
CLOUDFLARED_TUNNEL_TOKEN=

# ----- n8n -----
N8N_API_KEY=
N8N_ALLOW_ENV_ACCESS_IN_NODE=true
N8N_BLOCK_ENV_ACCESS=false

# ----- GitHub PAT (Portfolio.* workflows) -----
GITHUB_PAT=

# ----- Cortex endpoints -----
# Host callers (PowerShell, curl from this machine)
CORTEX_LLM_URL=http://localhost:8001
# Containers on the same host
CORTEX_LLM_URL_DOCKER=http://host.docker.internal:8001
